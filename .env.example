# Environment variables for DBT data paths
# Default paths for production/local use
RAW_FEATURES_GLOB='../data/raw/features_*.jsonl'
RAW_SUMMARY_GLOB='../data/raw/summary_*.jsonl'

# Optional runtime configuration
# Azure Blob container for raw and gold objects
BLOB_CONTAINER_NAME='raw-data'

# DBT job runtime paths
DBT_PROJECT_DIR='./dbt'
DBT_DATABASE_PATH='./dbt/greencar.duckdb'
TEMP_RAW_DIR='./tmp/raw'
TEMP_GOLD_DIR='./tmp/gold'

# For testing with fixtures (uncomment and adjust as needed)
# RAW_FEATURES_GLOB='../data/fixtures/features_test.jsonl'
# RAW_SUMMARY_GLOB='../data/fixtures/summary_test.jsonl'
